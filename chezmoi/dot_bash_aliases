# replace stale alias
unalias alex 2>/dev/null || true

# launch alex codex
function alex {
  local codex_launcher="$HOME/.local/bin/codex-with-worktree-greeting"
  local initial_prompt="$*"

  __potato_enter_readonly_worktree "$HOME/alex" "Alex" || return

  # forward prompt
  if [ "$#" -gt 0 ]; then
    "$codex_launcher" "$initial_prompt"
  else
    "$codex_launcher"
  fi
}
