# refresh detached head
__potato_refresh_detached_worktree() {
  local worktree_dir="$1"

  git -C "$worktree_dir" fetch origin &&
    git -C "$worktree_dir" checkout --detach origin/main
}

# enter named worktree
__potato_enter_worktree() {
  local worktree_dir="$1"
  local worktree_name="$2"
  local update_status=0

  # require worktree
  if [ ! -f "$worktree_dir/.git" ] && [ ! -d "$worktree_dir/.git" ]; then
    printf '%s\n' "$worktree_name: missing worktree at $worktree_dir" >&2
    return 1
  fi

  __potato_refresh_detached_worktree "$worktree_dir"
  update_status=$?

  # stop on refresh failure
  if [ "$update_status" -ne 0 ]; then
    return "$update_status"
  fi

  cd "$worktree_dir" || return
  printf '%s\n' "$worktree_name worktree refreshed at detached origin/main."
}

# mark alex writable
__potato_alex_writable() {
  chmod -R u+w "$HOME/alex" 2>/dev/null || true
}

# mark alex read-only
__potato_alex_readonly() {
  chmod -R a-w "$HOME/alex" 2>/dev/null || true
}

# enter read-only worktree
__potato_enter_readonly_worktree() {
  local worktree_dir="$1"
  local worktree_name="$2"
  local update_status=0

  # require worktree
  if [ ! -f "$worktree_dir/.git" ] && [ ! -d "$worktree_dir/.git" ]; then
    printf '%s\n' "$worktree_name: missing worktree at $worktree_dir" >&2
    return 1
  fi

  flock "$HOME/.alex-refresh.lock" sh -c '
    worktree_dir="$1"
    chmod -R u+w "$worktree_dir" 2>/dev/null || true
    git -C "$worktree_dir" fetch origin &&
      git -C "$worktree_dir" checkout --detach origin/main
    update_status=$?
    chmod -R a-w "$worktree_dir" 2>/dev/null || true
    exit "$update_status"
  ' sh "$worktree_dir"
  update_status=$?

  # stop on refresh failure
  if [ "$update_status" -ne 0 ]; then
    return "$update_status"
  fi

  cd "$worktree_dir" || return
  printf '%s\n' "$worktree_name read-only worktree refreshed at detached origin/main."
}

